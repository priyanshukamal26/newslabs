# ============================================================
# NewsLabs Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ============================================================

# ------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------
# PostgreSQL connection string.
# For Supabase: use the Transaction Pooler URL (port 6543) for
# Prisma with pgbouncer=true, or the Direct URL (port 5432)
# for migrations (DIRECT_URL).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# Optional: direct connection for prisma migrate
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ------------------------------------------------------------
# SECURITY
# ------------------------------------------------------------
# A long, random string used to sign JWT tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change_me_to_a_long_random_string"

# ------------------------------------------------------------
# SERVER
# ------------------------------------------------------------
# Port the Fastify server listens on.
# Render.com sets this to 10000 automatically.
PORT="3000"

# ------------------------------------------------------------
# AI PROVIDER
# ------------------------------------------------------------
# Which AI service to use for article summarization:
#   groq    — Groq only (fast inference, free tier available)
#   gemini  — Google Gemini only
#   hybrid  — Groq first, auto-fallback to Gemini on rate-limit
AI_PROVIDER="hybrid"

# ------------------------------------------------------------
# GROQ
# ------------------------------------------------------------
# Get your key at: https://console.groq.com
GROQ_API_KEY="gsk_your_groq_api_key_here"

# Model to use for Groq inference (default below is recommended)
GROQ_MODEL="llama-3.1-8b-instant"

# ------------------------------------------------------------
# GEMINI (optional, required for hybrid / gemini mode)
# ------------------------------------------------------------
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# Gemini model name
GEMINI_MODEL="gemini-2.5-flash"
